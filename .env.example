# Secret used to sign session JWTs; set a long random value outside local dev
JWT_SECRET=change-me-to-a-long-random-string
# Anthropic API key for live LLM stages; keyless mode serves deterministic fallbacks
ANTHROPIC_API_KEY=
# Email delivery: console (log only) or smtp
EMAIL_PROVIDER=console
# Model backend: real (trained CNNs, vendored in backend/weights/) or stub
# (hash-derived deterministic outputs; also the automatic fallback if the ml
# extra or the weights are missing)
MODEL_BACKEND=real
# Set true when serving over HTTPS so session cookies are marked Secure
COOKIE_SECURE=false
# Frontend origin allowed by the CSRF origin check
APP_ORIGIN=http://localhost:3000
